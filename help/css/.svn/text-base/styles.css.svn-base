/*<group=General Styles>*/

body {
/*    background: url(../img/background_red.jpg) repeat;*/
    margin: 0;
    font: 1em  Georgia, Times New Roman, Times, serif;
    color: #4E3E20 /*#6E4F16 #38385C #34347D #4848DE #452121 #6D3737  #6f4714*/ ;
    text-align: right;

}

p {
}

b, strong {

}

a:link, a:visited {
/*    text-decoration: underline;*/
    text-decoration: none;
    color: #7e0100;
}

a:hover, a:active {
    text-decoration: none;
    color: #6f4714;
}

img {
    border-style: none;
}

.image-left {
    float: left;
    margin: 1px 1px 1px 0;
    padding: 1px 1px 1px 0;
}

.image-right {
    float: right;
    margin: 1px 0 1px 1px;
    padding: 1px 0 1px 1px;
}


/* </group> */
/*<group=Layout>*/
#container {
/*851023
width: 780px;

    padding-left: 0px;
*/
    text-align: right;
}

.clearer {
    clear: both;
}

#pageHeader {
    /*background: url(../img/header_background.jpg) ;*/
    height: 98px;
    text-align: center;
    margin-top:5px;
}

#pageHeader img {
    float: left;
    padding-right: 0px;
}

#pageHeader h1 {
    color: #ffffff;
    text-shadow: 0px 0px 4px #76a8db;
    padding-top: 15px;
    padding-left: 40px;
    font-size: 1em;
    margin: 0px;
}

#pageHeader h2 {
    color: #ffffff;
    text-shadow: 0px 0px 2px #76a8db;
    padding-left: 40px;
	padding-top: 0px;
    font-size: 1em;
    margin: 0px;
}

/*#pageFooter {
    background: url(../img/footer_background.jpg) ;
    height: 78px;
